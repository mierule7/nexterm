{
  "name": "nexterm",
  "version": "1.0.0",
  "description": "Cross-platform SSH/SFTP/Remote Desktop client",
  "main": "src/main/main.js",
  "author": {
  "name": "Amirul Hafiz",
  "email": "mierule7@gmail.com"
},
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder"
  },
  "dependencies": {
    "ssh2": "^1.15.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0",
    "node-forge": "^1.3.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
  "appId": "com.nexterm.app",
  "productName": "NexTerm",
  "directories": {
    "output": "dist"
  },
  "linux": {
    "target": ["AppImage", "deb"],
    "category": "Utility"
  },
  "win": {
    "target": "nsis"
  },
  "mac": {
    "target": "dmg"
  }
}
}
